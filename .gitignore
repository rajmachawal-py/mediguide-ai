# ============================================================
# MediGuide AI — .gitignore
# ============================================================


# ══════════════════════════════════════════════════════════════
# 🔐 CONFIDENTIAL / SECRETS — NEVER COMMIT THESE
# ══════════════════════════════════════════════════════════════

# ── Environment Variable Files ───────────────────────────────
.env
.env.*
.env.local
.env.*.local
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*
frontend/.env.local
frontend/.env.*.local

# ── Google OAuth Client Secrets ──────────────────────────────
client_secret*.json
*client_secret*.json

# ── Firebase / FCM Credentials ───────────────────────────────
*firebase-adminsdk*.json
*serviceAccountKey*.json
*service-account*.json
*service_account*.json
google-services.json
GoogleService-Info.plist
backend/mediguide-ai-239a5-firebase-adminsdk-fbsvc-19d7770c71.json

# ── Google Cloud Credentials ─────────────────────────────────
*-credentials.json
gcp-credentials.json
google-cloud-key.json
keyfile.json
mediguide-ai-*.json

# ── SSL / TLS Certificates ───────────────────────────────────
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx

# ── Catch-all Secrets Patterns ───────────────────────────────
*secret*
*secrets*
*private_key*
*api_key*
*apikey*
*.token


# ══════════════════════════════════════════════════════════════
# 🐍 PYTHON
# ══════════════════════════════════════════════════════════════

# Bytecode / Cache
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# Virtual Environments
.venv/
venv/
env/
ENV/
backend/mediguide-venv/
backend/mediguide-Venv/
backend/venv/
backend/.venv/
**/mediguide-Venv/
**/mediguide-venv/

# Python version file (auto-generated by uv)
.python-version

# Distribution / Packaging
build/
dist/
*.egg-info/
*.egg
.eggs/

# Testing
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.lcov

# mypy
.mypy_cache/
.dmypy.json


# ══════════════════════════════════════════════════════════════
# 📦 NODE.JS / FRONTEND
# ══════════════════════════════════════════════════════════════

# Dependencies
node_modules/
frontend/node_modules/

# Build Output
frontend/dist/
frontend/build/
frontend/.vite/

# Lock files (optional — uncomment if you want to commit them)
package-lock.json
frontend/package-lock.json
yarn.lock
pnpm-lock.yaml
pyproject.toml
uv.lock

# Debug Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ══════════════════════════════════════════════════════════════
# 🛠️ TOOLING / IDE / OS
# ══════════════════════════════════════════════════════════════

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS Generated
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Gemini / Antigravity Agent
.gemini/

# Supabase Local
supabase/.branches/
supabase/.temp/
.supabase/

# Render.com
.render/


# ══════════════════════════════════════════════════════════════
# 📝 LOGS / TEMP / GENERATED
# ══════════════════════════════════════════════════════════════

# Logs
*.log
logs/
backend/logs/
frontend/logs/

# Temp / Scratch
scratch/
tmp/
temp/

# Test scripts
backend/test_*.py
test_*.py

# Generated audio (TTS output)
*.wav
*.mp3
tts_output.*
